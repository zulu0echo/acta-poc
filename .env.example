# ACTA (Anonymous Credentials for Trustless Agents) — Environment Variables
# Copy to .env and fill in values

# Base Sepolia RPC (leave blank for local Hardhat node)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private keys (generated automatically if not set)
# WARNING: Never commit real private keys to source control
ISSUER_PRIVATE_KEY=
HOLDER_PRIVATE_KEY=
VERIFIER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# Wallet encryption keys
WALLET_KEY=insecure-dev-key-replace-in-production

# Service URLs
ISSUER_BASE_URL=http://localhost:3001
VERIFIER_BASE_URL=http://localhost:3003

# Deployed contract addresses (populated by deploy script)
NULLIFIER_REGISTRY_ADDRESS=
CREDENTIAL_ANCHOR_ADDRESS=
GP_VERIFIER_ADDRESS=
ZK_REPUTATION_ADDRESS=
AGENT_ACCESS_GATE_ADDRESS=

# External API keys (optional)
BASESCAN_API_KEY=
COINMARKETCAP_API_KEY=
REPORT_GAS=false
